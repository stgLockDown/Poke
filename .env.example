# =============================================================================
# PokeAlert environment configuration
# =============================================================================
# Copy this file to .env and fill in whichever sections you plan to use.
#
# IMPORTANT: Do NOT put inline comments on the same line as a value — some
# dotenv parsers capture the comment as part of the value.
# =============================================================================


# ============================================================
# DISCORD — Per-retailer channels (one webhook URL each)
# Create webhooks in Discord: Server Settings → Integrations → Webhooks
# You can give each retailer its own channel for clean routing.
# ============================================================
DISCORD_WEBHOOK_POKEMONCENTER=
DISCORD_WEBHOOK_TARGET=
DISCORD_WEBHOOK_BESTBUY=
DISCORD_WEBHOOK_WALMART=
DISCORD_WEBHOOK_GAMESTOP=
DISCORD_WEBHOOK_AMAZON=
DISCORD_WEBHOOK_COSTCO=

# Fallback for any retailer without a dedicated webhook above
DISCORD_WEBHOOK_URL=

# Special-purpose channels
# Web-search restock scout posts here:
DISCORD_WEBHOOK_WEB_RESTOCKS=
# Periodic heartbeat / health pings post here:
DISCORD_WEBHOOK_HEARTBEAT=


# ============================================================
# DISCORD — Optional role mentions (one per retailer or global fallback)
# Use the role ID (e.g. 1234567890), not the role name.
# ============================================================
DISCORD_ROLE_ID=
DISCORD_ROLE_POKEMONCENTER=
DISCORD_ROLE_TARGET=
DISCORD_ROLE_BESTBUY=
DISCORD_ROLE_WALMART=
DISCORD_ROLE_GAMESTOP=
DISCORD_ROLE_AMAZON=
DISCORD_ROLE_COSTCO=


# ============================================================
# TELEGRAM (optional)
# ============================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ============================================================
# EMAIL / SMTP (optional)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=


# ============================================================
# RETAILER API KEYS
# ============================================================
# Best Buy Products API — free at https://developer.bestbuy.com/
BESTBUY_API_KEY=

# Amazon Product Advertising API 5.0 — requires Associates account
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_ASSOCIATE_TAG=
AMAZON_REGION=us-east-1


# ============================================================
# WEB-SEARCH PROVIDER (pick ONE — for the web-restocks scout)
# ============================================================
# Brave Search — https://api.search.brave.com/ (free tier: 2k queries/mo)
BRAVE_API_KEY=

# OR Serper.dev — https://serper.dev/
SERPER_API_KEY=

# OR SerpAPI — https://serpapi.com/
SERPAPI_API_KEY=


# ============================================================
# LOCAL STOCK DEFAULTS
# ============================================================
# Used by Target + Best Buy when a product doesn't specify its own zip
DEFAULT_ZIP_CODE=


# ============================================================
# BEHAVIOR & DEPLOYMENT
# ============================================================
LOG_LEVEL=INFO
USER_AGENT=PokeAlert/1.1 (+https://github.com/stgLockDown/Poke; ethical-stock-monitor)

# Leave PORT empty for local; Railway sets it automatically.
PORT=


# ============================================================
# PROXY (optional but STRONGLY recommended for Railway/cloud hosts)
# ============================================================
# GameStop, Walmart, Target and most major retailers actively block
# requests from cloud/datacenter IPs (Railway, Fly, Render, AWS, etc.).
# No API key or code fix can get around that — it is an IP-reputation
# problem at the retailer's CDN/WAF layer.
#
# The standard solution is to route outbound traffic through a
# residential or mobile proxy. When PROXY_URL is set, PokeAlert:
#   * Sends all HTTP requests through the proxy
#   * Switches to a rotating browser User-Agent (instead of self-ID bot UA)
#   * Adds normal browser headers (Sec-Fetch-*, Accept, etc.)
#
# Format examples:
#   PROXY_URL=http://user:pass@proxy.example.com:8000
#   PROXY_URL=https://user:pass@proxy.example.com:8443
#   PROXY_URL=socks5://user:pass@proxy.example.com:1080
#
# Recommended providers (pick one):
#   * Webshare         (cheapest, from ~$3/mo for 10 rotating proxies)
#                      https://www.webshare.io/
#   * IPRoyal          (pay-as-you-go residential)
#                      https://iproyal.com/
#   * Bright Data      (enterprise, highest quality, higher cost)
#                      https://brightdata.com/
#   * Oxylabs          (enterprise residential/mobile)
#                      https://oxylabs.io/
#   * SmartProxy       (mid-tier residential pool)
#                      https://smartproxy.com/
#
# NOTE: Using a proxy to access retailer sites is YOUR responsibility
# under each retailer's Terms of Service. A rotating residential proxy
# intentionally hides that you are a bot — this is a conscious
# trade-off between "polite but blocked" and "functional but more
# aggressive". Use at a reasonable request rate.
PROXY_URL=